{
  "name": "CAPMTraining",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.29"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-incidentui": "cds watch --open incidentui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy CAPMTraining --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "mbt build && cf deploy mta_archives/CAPMTraining_1.0.0.mtar",
    "watch-customui": "cds watch --open customui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "metadata": {
        "kind": "odata-v2",
        "csrf": true,
        "csrfInBatch": true,
        "model": "srv/external/metadata",
        "credentials": {
          "destination": "Northwind"
        }
      },
      "html5-repo": true,
      "db": "hana"
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/incidentui"
  ]
}